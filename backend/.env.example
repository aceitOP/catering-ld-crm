# Databáze
DATABASE_URL=postgres://catering:changeme123@localhost:5432/catering_ld
DB_SEED_MODE=empty

# JWT
JWT_SECRET=superSecretKey2026changeMe!!CHANGE_IN_PROD
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Prvni super admin pro cistou instalaci
SUPER_ADMIN_EMAIL=pomykal@aceit.cz
SUPER_ADMIN_PASSWORD=CHANGE_ME_SUPER_SECRET
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=15

# Google Calendar (volitelné)
# Service Account JSON klíč – celý obsah JSON souboru na jednom řádku
# Získejte v Google Cloud Console → IAM → Service Accounts → Vytvořit → stáhnout JSON klíč
# Poté sdílejte Google Kalendář s emailem service accountu (role: Správa událostí)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# Tally.so webhook zabezpečení (volitelné)
# V produkci doporučeno povinně nastavit
# TALLY_KEY=tajny_klic

# Povolení self-signed TLS certifikátů pro SMTP/IMAP (pouze výjimečně)
# ALLOW_SELF_SIGNED_EMAIL_TLS=false
